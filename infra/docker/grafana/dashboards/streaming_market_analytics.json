          "rawSql": "WITH aggregated AS ( SELECT if('${timeframe}' = '5m', toStartOfInterval(open_time, INTERVAL 5 MINUTE), open_time) AS bucket_start, argMax(close, open_time) AS close_price, sum(volume) AS total_volume FROM raw_ohlcv_1m WHERE symbol = '${symbol}' AND open_time >= now() - INTERVAL 24 HOUR GROUP BY bucket_start ), running AS ( SELECT bucket_start, close_price, total_volume, sum(close_price * total_volume) OVER (ORDER BY bucket_start ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) / nullIf(sum(total_volume) OVER (ORDER BY bucket_start ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW), 0) AS session_vwap FROM aggregated ) SELECT bucket_start AS time, close_price AS close, session_vwap AS vwap FROM running ORDER BY time",
