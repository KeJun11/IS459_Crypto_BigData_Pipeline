          "editorType": "sql",
          "format": 1,
          "pluginVersion": "11.1.0",
          "queryType": "table",
          "rawSql": "WITH aggregated AS ( SELECT if('${timeframe}' = '5m', toStartOfInterval(open_time, INTERVAL 5 MINUTE), open_time) AS bucket_start, argMin(open, open_time) AS open_price, max(high) AS high_price, min(low) AS low_price, argMax(close, open_time) AS close_price, sum(volume) AS total_volume FROM raw_ohlcv_1m WHERE symbol = '${symbol}' AND open_time >= now() - INTERVAL 24 HOUR GROUP BY bucket_start ) SELECT bucket_start AS time, close_price AS close, avg(close_price) OVER (ORDER BY bucket_start ROWS BETWEEN 4 PRECEDING AND CURRENT ROW) AS trend_fast, avg(close_price) OVER (ORDER BY bucket_start ROWS BETWEEN 14 PRECEDING AND CURRENT ROW) AS trend_slow FROM aggregated ORDER BY time",
          "refId": "A"
        }
      ],
      "title": "Close With Fast/Slow Trend Overlays",
      "type": "timeseries"
    },
