{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/kline_1m.schema.json",
  "title": "Binance 1m Kline",
  "description": "Canonical message contract for 1-minute OHLCV candles sent through Kinesis.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "symbol": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Z0-9_]+$"
    },
    "open": {
      "type": "number"
    },
    "high": {
      "type": "number"
    },
    "low": {
      "type": "number"
    },
    "close": {
      "type": "number"
    },
    "volume": {
      "type": "number",
      "minimum": 0
    },
    "open_time": {
      "type": "integer",
      "description": "Unix epoch timestamp in milliseconds."
    },
    "close_time": {
      "type": "integer",
      "description": "Unix epoch timestamp in milliseconds."
    },
    "is_closed": {
      "type": "boolean"
    }
  },
  "required": [
    "symbol",
    "open",
    "high",
    "low",
    "close",
    "volume",
    "open_time",
    "close_time",
    "is_closed"
  ],
  "allOf": [
    {
      "properties": {
        "high": {
          "minimum": 0
        },
        "low": {
          "minimum": 0
        },
        "open": {
          "minimum": 0
        },
        "close": {
          "minimum": 0
        }
      }
    }
  ]
}
